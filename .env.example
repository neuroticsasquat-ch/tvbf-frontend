# Copy to .env.local and adjust as needed. .env.local is gitignored.
VITE_API_BASE_URL=https://tvbf-backend.localhost
# VITE_SENTRY_DSN=<your-tvbf-frontend-Sentry-DSN>
# VITE_GIT_SHA=$CF_PAGES_COMMIT_SHA pnpm install --frozen-lockfile && pnpm build

# --- Production build only (set in the Cloudflare Pages build environment, not .env.local) ---
# When SENTRY_AUTH_TOKEN is set, the Vite build uploads source maps to Sentry and
# deletes them from the output. Unset (local/dev) builds skip this step entirely.
# SENTRY_AUTH_TOKEN=<sentry-org-auth-token>
# SENTRY_ORG=neuroticsasquatch
# SENTRY_PROJECT=tvbf-frontend
